rules_version = '2';

// ════════════════════════════════════════════════════════════════════
// SOULEO · Firebase Storage Rules
// ════════════════════════════════════════════════════════════════════
// Arquitetura:
// - Uploads: SEMPRE pelo servidor (firebase-admin via /api/upload-pdf)
//   → Admin SDK bypassa estas regras
// - Leituras: PDFs sao publicos (URLs storage.googleapis.com)
// - Browser NUNCA escreve direto
// ════════════════════════════════════════════════════════════════════

service firebase.storage {
  match /b/{bucket}/o {

    // ── PDFs de laudos ──
    // Path: laudos/{wsId}/{nomeArq}.pdf
    // Leitura publica (URLs compartilhadas com pacientes)
    // Escrita bloqueada (so admin SDK escreve)
    match /laudos/{wsId}/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    // ── Logos de clinica (futuro) ──
    // Path: logos/{wsId}/{fileName}
    // Leitura publica (logo aparece no PDF)
    // Escrita: admin SDK ou usuario autenticado dono do workspace
    match /logos/{wsId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 2 * 1024 * 1024  // max 2MB
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Assinaturas digitais (futuro) ──
    // Path: assinaturas/{uid}/{fileName}
    // Leitura publica (assinatura aparece no PDF)
    // Escrita: so o proprio usuario
    match /assinaturas/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 1 * 1024 * 1024  // max 1MB
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Anexos de exames (futuro - DICOM, fotos) ──
    // Path: anexos/{wsId}/{exameId}/{fileName}
    // Leitura: usuario autenticado
    // Escrita: admin SDK
    match /anexos/{wsId}/{exameId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── DICOM previews (JPGs gerados pelo Wader a partir do Orthanc) ──
    // Path: dicom/{wsId}/{exameId}/{seq}.jpg
    // Leitura PUBLICA — o <img src={url}> no browser nao envia token,
    // e a URL e longa+aleatoria (wsId + exameId Firestore IDs).
    // Adicionado em 14/05/2026 (antes disso, comentario do
    // storage-uploader.ts mentia dizendo que existia essa regra; URLs
    // davam 403 Forbidden em producao).
    // Escrita: bloqueada no browser; Wader sobe via firebase-admin (bypassa).
    match /dicom/{wsId}/{exameId}/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    // ── DENY DEFAULT ──
    // Qualquer outro path: bloqueado total
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
